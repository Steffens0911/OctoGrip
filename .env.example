# PostgreSQL (usado pelo docker-compose e pela API)
POSTGRES_USER=jjb
POSTGRES_PASSWORD=jjb_secret
POSTGRES_DB=jjb_db

# URL de conexão (API usa isso; no Docker o host é "postgres")
# Para rodar só a API localmente apontando para o Postgres no Docker:
# DATABASE_URL=postgresql://jjb:jjb_secret@localhost:5432/jjb_db
DATABASE_URL=postgresql://jjb:jjb_secret@postgres:5432/jjb_db

# JWT — OBRIGATÓRIO em produção (gere com: python -c "import secrets; print(secrets.token_urlsafe(64))")
# JWT_SECRET=coloque-um-secret-forte-aqui

# CORS — JSON com origens explícitas (produção). Dev: pode omitir ([]); localhost:any usa regex na API.
# Não use ["*"] com Flutter Web + JWT — o browser bloqueia. Ex.: CORS_ORIGINS=["https://app.exemplo.com"]
# CORS_ORIGINS=["http://localhost:8080"]

# Pool de conexões do banco
# DB_POOL_SIZE=20
# DB_MAX_OVERFLOW=30

# Seed automático no startup (desabilite em produção se não quiser)
# SEED_ON_STARTUP=true

# Rate limiting no login (slowapi format)
# LOGIN_RATE_LIMIT=5/minute

# URL da API para o app viewer (build Flutter). O browser acessa pelo host.
# Padrão: http://localhost:8000 (tudo no mesmo host)
# API_BASE_URL=http://localhost:8000
#
# --- Caddy (docker-compose.caddy.yml) ---
# Domínios públicos com TLS automático. Obrigatórios ao usar o override Caddy.
# APP_DOMAIN=app.seudominio.com
# API_DOMAIN=api.seudominio.com
# API_BASE_URL=https://api.seudominio.com
# CORS_ORIGINS=["https://app.seudominio.com"]

# Observabilidade
# Formato de logs: "text" (padrão) ou "json"
# LOG_FORMAT=text

# Sentry DSN para error tracking (opcional)
# SENTRY_DSN=

# Habilitar endpoint de métricas Prometheus (padrão: true)
# ENABLE_METRICS=true
