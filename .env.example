# PostgreSQL (usado pelo docker-compose e pela API)
POSTGRES_USER=jjb
POSTGRES_PASSWORD=jjb_secret
POSTGRES_DB=jjb_db

# URL de conexão (API usa isso; no Docker o host é "postgres")
# Para rodar só a API localmente apontando para o Postgres no Docker:
# DATABASE_URL=postgresql://jjb:jjb_secret@localhost:5432/jjb_db
DATABASE_URL=postgresql://jjb:jjb_secret@postgres:5432/jjb_db

# URL da API para o app viewer (build Flutter). O browser acessa pelo host.
# Padrão: http://localhost:8000 (tudo no mesmo host)
# API_BASE_URL=http://localhost:8000
